{
  "expo": {
    "name": "GestY",
    "slug": "gesty",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icons/icon.png",
    "scheme": "gesty",
    "experiments": {
      "typedRoutes": true
    },
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yannlo.gesty"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#185D23",
        "foregroundImage": "./assets/images/icons/android/icon-foreground.png",
        "backgroundImage": "./assets/images/icons/android/icon-background.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.yannlo.gesty"
    },
    "web": {
      "favicon": "./assets/images/icons/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/BalooBhai2-Regular.ttf",
            "./assets/fonts/BalooBhai2-Bold.ttf",
            "./assets/fonts/BalooBhai2-Medium.ttf",
            "./assets/fonts/BalooBhai2-SemiBold.ttf",
            "./assets/fonts/BalooBhai2-ExtraBold.ttf"
          ]
        }
      ]
    ]
  }
}
